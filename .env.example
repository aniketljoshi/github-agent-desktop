# GitHub Agent Desktop — Environment Variables
# Copy this file to .env and fill in the values you need.

# ─── GitHub OAuth App ───────────────────────────────────────
# Register at https://github.com/settings/developers
# Enable Device Flow in app settings
# client_id is public and safe to ship in the app binary.
# For browser redirect login in local development, also set GITHUB_CLIENT_SECRET
# and configure the OAuth app callback URL to match GITHUB_CALLBACK_URL exactly.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://127.0.0.1:48163/callback

# ─── BYOK (Bring Your Own Key) ─────────────────────────────
# Only needed if you want to use a non-GitHub provider for Ask/Plan.
# Supported: openai, anthropic, ollama
BYOK_PROVIDER=
BYOK_API_KEY=
BYOK_BASE_URL=

# ─── Development ────────────────────────────────────────────
# Set to "true" to enable verbose IPC logging in the dev console.
DEBUG_IPC=false
