# GitHub Agent Desktop - Environment Variables
# Copy this file to .env.local for local development.
#
# Packaged desktop builds also load runtime config from:
# 1. the directory next to the executable
# 2. the app resources directory
# 3. the Electron userData directory
#
# For local packaged testing, place a .env.local file next to the .exe or .app bundle resources.

# GitHub OAuth App
# Register at https://github.com/settings/developers
# Enable Device Flow in app settings.
# client_id is public and safe to ship in the app binary.
# For browser redirect login, also set GITHUB_CLIENT_SECRET and make the
# OAuth callback URL match GITHUB_CALLBACK_URL exactly.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://127.0.0.1:48163/callback

# BYOK (Bring Your Own Key)
# Only needed if you want to use a non-GitHub provider for Ask/Plan.
# Supported: openai, anthropic, ollama
BYOK_PROVIDER=
BYOK_API_KEY=
BYOK_BASE_URL=

# Development
# Set to "true" to enable verbose IPC logging in the dev console.
DEBUG_IPC=false
